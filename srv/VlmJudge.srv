# Request
string[] image_paths      # 다각도 이미지 경로 (2~4장)
string object_name        # 반품 제품명
string return_reason      # 반품 사유
---
# Response
bool success              # 서비스 호출 성공 여부
string decision           # RETURN_APPROVED / RETURN_REJECTED / MANUAL_REVIEW
string damage_status      # 있음 / 없음 / 애매함
string reason             # VLM 판정 근거
float64 inference_time    # 추론 시간 (초)
